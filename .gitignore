# ---- Python / env ----
.venv/
venv/
.env
.env.*
!.env.example
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---- OS / editor ----
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# ---- Data ----
data/raw/**
data/processed/**
data/duckdb/**
data/OLD_processed/**

# Keep folder structure on fresh clones so scripts don't crash.
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/duckdb/.gitkeep

# Processed parquets + numpy artifacts ARE tracked (via Git LFS).
# Tracked patterns are configured in .gitattributes.
!data/processed/*.parquet
!data/processed/*.npy

# ---- Build / archive artifacts (never commit these) ----
*.zip
*.tar
*.tar.gz
*.tar.zst
*.7z
*.rar
*.duckdb

# ---- Logs / misc ----
*.log
.cache/
